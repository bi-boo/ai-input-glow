{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "2.0",
  "description": "__MSG_extensionDescription__",
  "author": "重音",
  "homepage_url": "https://github.com/bi-boo/ai-input-glow",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_extensionName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon48.png",
      "32": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "css": ["styles/glow.css"],
      "js": ["modules/glow.js"],
      "all_frames": true
    }
  ],
  "default_locale": "zh_CN"
}